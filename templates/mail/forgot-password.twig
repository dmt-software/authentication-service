{% block content %}
    <h4>Hello {{ userToken.user.fullName|default("User") }},</h4>

    <p>
        We received a request to <a href="{{ app.url }}/reset-password/{{ userToken.token }}">reset</a> your password.
    </p>

    <p>
        If you did not request this, you can ignore this email.
    </p>

    {% if userToken.expiresAt %}
        <span style="font-size: 13px; color: #6c757d;">
            this link expires at {{ userToken.expiresAt|date('Y-m-d H:i') }}.
        </span>
    {% endif %}
{% endblock %}