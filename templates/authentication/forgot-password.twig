{% block content %}
    <h1>forgot password</h1>

    {% if error %}
        <span style="color: red">{{ error }}</span>
    {% elseif success %}
        <span style="color: green">{{ success }}</span>
    {% endif %}

    <form method="post">
        <div>
            <label for="email">email</label>
            <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
            >
        </div>

        <button type="submit">request new password</button>

        <div>
            <a href="/login">back to login</a>
        </div>
    </form>
{% endblock %}